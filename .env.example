# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# ⚠️  Ne jamais exposer cette clé côté client (server-only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# IDs des prix Stripe (Stripe Dashboard > Products)
NEXT_PUBLIC_STRIPE_PRICE_MENSUEL=price_...
NEXT_PUBLIC_STRIPE_PRICE_ANNUEL=price_...

# ─── Application ─────────────────────────────────────────────────────────────
# URL publique de l'app (sans slash final)
NEXT_PUBLIC_APP_URL=https://votre-domaine.fr

# ─── Cloudflare Turnstile (CAPTCHA) ──────────────────────────────────────────
# Créer un site sur : https://dash.cloudflare.com > Turnstile
# Sélectionner "Managed" (invisible pour la plupart des utilisateurs)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
# La clé secrète est à configurer UNIQUEMENT dans Supabase Dashboard :
#   Authentication > Attack Protection > Enable CAPTCHA > Cloudflare Turnstile

# ─── Email (Supabase Edge Functions + Resend) ────────────────────────────────
# Ces valeurs doivent AUSSI être définies dans Supabase :
#   npx supabase secrets set RESEND_API_KEY=re_... FUNCTION_SECRET=...
RESEND_API_KEY=re_...
FUNCTION_SECRET=your_random_secret_here

# ─── Push notifications PWA (VAPID) ──────────────────────────────────────────
# Générer une paire de clés VAPID : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ─── Google Analytics (optionnel) ────────────────────────────────────────────
# GA4 Measurement ID — chargé uniquement après consentement CNIL
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
